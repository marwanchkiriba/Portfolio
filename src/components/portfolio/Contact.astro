---
import { Icon } from "astro-icon/components";
import Heading from "../ui/Heading.astro";
import Button from "../ui/Button.astro";

const email = "marwanchkiriba9@gmail.com";
---

<section
  class="py-8 px-8 max-md:py-4 mb-4 scroll-m-16"
  id="contact"
  aria-label="Section de contact"
>
  <div class="flex flex-col gap-8 pt-8 max-w-4xl mx-auto">
    <div class="flex gap-4 items-center justify-center">
      <Icon class="text-3xl dark:text-white text-blacktext" name="envelope" />
      <Heading text="Me" textGradient="Contacter" level={2} />
    </div>

    <div class="flex flex-col gap-4 items-center justify-center">
      <p
        class="text-center text-lg max-xl:text-base max-w-2xl dark:text-gray-200 text-blacktext my-6 leading-6 font-medium"
      >
        Vous avez un projet intéressant ? Je serais ravi d'en discuter avec vous !
        <br />
        N'hésitez pas à me contacter par email.
      </p>

      <Button link={"mailto:" + email} text="Envoyer un email" iconName="envelope" />
    </div>
  </div>
</section>
